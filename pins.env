# pf-hwprobe — pinned refs for the reproducible build.
#
# Every external source pulled by build.sh + docker/Dockerfile resolves through this file
# (matches the sim's docker/*.pin pattern; committed so a rebuild months later is byte-
# for-byte the same as today). Update pins on their own PR with a short rationale.

# E2 runtime (libpocketforge C ABI). ABI frozen v1 (runtime/STABILITY.md).
RUNTIME_REPO=https://github.com/pocketforge-os/runtime.git
RUNTIME_COMMIT=0fedcdbadbcc0415687ed4861b163e3f36320ef3
RUNTIME_REF=origin/main

# E5 simulator + its bundled SDL3 render build (feeds the sim harness).
# Bumped 2026-07-11 (tsp-fr2n.7) to the merged sim PR #20 head so hwprobe-smoke.yml
# re-runs against the sim commit that ships --only-launcher / --outdir-base /
# --label + the descriptor-dispatched HEADLINE that check-control-hwprobe.py needs.
SIM_REPO=https://github.com/pocketforge-os/sim.git
SIM_COMMIT=7d0c3c9fc6e80fd7792c99cc6a77b564b24fdc7e
SIM_REF=origin/main

# E1 platform descriptors (read-only consumer; verifies the a133/a523 delta).
PLATFORM_REPO=https://github.com/pocketforge-os/platform.git
PLATFORM_COMMIT=253607fad632847b39d41c3b55aa417d3b0d5412
PLATFORM_REF=origin/main

# Toolchain image (Rust + gcc-aarch64 cross); newer Rust needed for indexmap
# 2.14+ which pulls edition2024 (rust >= 1.85). runtime/Cargo.toml only asserts
# MSRV 1.77 for its own code — the crates.io dep graph is the actual gate.
RUST_IMAGE=rust:1.85-bookworm
